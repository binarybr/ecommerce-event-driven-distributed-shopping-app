{
  "info": {
    "name": "ShopSphere - End to End",
    "description": "Full end-to-end test flow for the ShopSphere microservices backend, through the API Gateway (default http://localhost:8080).\n\nRun the folders top-to-bottom (or use the Collection Runner). Test scripts automatically capture and chain variables: login token -> product id -> cart -> order -> payment -> review.\n\nVariables are stored at the COLLECTION level, so it works even without an environment. Override {{baseUrl}} (e.g. to your AWS public IP:8080) via an environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "custEmail", "value": "" },
    { "key": "custPassword", "value": "Passw0rd!" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "productPrice", "value": "" },
    { "key": "newProductId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "cartTotal", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "orderNumber", "value": "" },
    { "key": "orderPrice", "value": "" },
    { "key": "paymentId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "// Generate a unique customer email so re-runs don't hit the duplicate-email check",
                "const email = `cust_${Date.now()}@test.com`;",
                "pm.collectionVariables.set('custEmail', email);",
                "pm.collectionVariables.set('custPassword', 'Passw0rd!');"
              ] }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('201 Created', () => pm.response.code === 201);",
                "console.log('Registered:', pm.collectionVariables.get('custEmail'));"
              ] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{custEmail}}\",\n  \"password\": \"{{custPassword}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Customer\",\n  \"phone\": \"9876543210\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/register", "host": ["{{baseUrl}}"], "path": ["api","users","register"] }
          }
        },
        {
          "name": "Login Customer",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.code === 200);",
            "const b = pm.response.json();",
            "pm.collectionVariables.set('token', b.accessToken);",
            "pm.collectionVariables.set('userId', String(b.user.id));",
            "pm.test('got JWT', () => pm.expect(b.accessToken).to.be.a('string'));",
            "console.log('Customer token captured, userId=', b.user.id, 'role=', b.user.role);"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{custEmail}}\",\n  \"password\": \"{{custPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api","users","login"] }
          }
        },
        {
          "name": "Login Admin (seeded)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.code === 200);",
            "const b = pm.response.json();",
            "pm.collectionVariables.set('adminToken', b.accessToken);",
            "pm.test('role is ADMIN', () => pm.expect(b.user.role).to.eql('ADMIN'));",
            "console.log('Admin token captured');"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@shopsphere.com\",\n  \"password\": \"Admin@1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api","users","login"] }
          }
        },
        {
          "name": "Register Admin (with key) [optional]",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "pm.collectionVariables.set('newAdminEmail', `admin_${Date.now()}@test.com`);"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201 Created', () => pm.response.code === 201);",
              "console.log('New admin registered:', pm.collectionVariables.get('newAdminEmail'));"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{newAdminEmail}}\",\n  \"password\": \"AdminPass1\",\n  \"firstName\": \"New\",\n  \"lastName\": \"Admin\",\n  \"phone\": \"9000000000\",\n  \"adminKey\": \"ShopSphere@Admin2024\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/register", "host": ["{{baseUrl}}"], "path": ["api","users","register"] }
          }
        }
      ]
    },
    {
      "name": "2. Catalog (public)",
      "item": [
        {
          "name": "List Products",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.code === 200);",
            "const arr = pm.response.json();",
            "pm.test('has products', () => pm.expect(arr.length).to.be.above(0));",
            "pm.collectionVariables.set('productId', arr[0].id);",
            "pm.collectionVariables.set('productPrice', arr[0].price);",
            "console.log('Picked product', arr[0].name, '@', arr[0].price, 'id=', arr[0].id);"
          ] } } ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] } }
        },
        {
          "name": "Get Product By Id",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{productId}}"] } }
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/products/search?q=wireless&sortBy=price&sortDir=ASC&page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api","products","search"], "query": [ {"key":"q","value":"wireless"}, {"key":"sortBy","value":"price"}, {"key":"sortDir","value":"ASC"}, {"key":"page","value":"0"}, {"key":"size","value":"10"} ] } }
        }
      ]
    },
    {
      "name": "3. Admin Setup (create product + stock)",
      "item": [
        {
          "name": "Create Product (ADMIN)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 Created', () => pm.response.code === 201);",
            "const b = pm.response.json();",
            "pm.collectionVariables.set('newProductId', b.id);",
            "console.log('Created product id=', b.id);"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Postman Test Speaker\",\n  \"description\": \"A product created via the Postman E2E collection.\",\n  \"price\": 129.99,\n  \"category\": \"Audio\",\n  \"brand\": \"TestBrand\",\n  \"sku\": \"PM-TEST-001\",\n  \"imageUrl\": \"https://example.com/speaker.jpg\",\n  \"tags\": [\"test\", \"audio\"],\n  \"stock\": 25\n}" },
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] }
          }
        },
        {
          "name": "Add Inventory for New Product (ADMIN)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 Created', () => pm.response.code === 201);"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{newProductId}}\",\n  \"quantity\": 25\n}" },
            "url": { "raw": "{{baseUrl}}/api/inventory", "host": ["{{baseUrl}}"], "path": ["api","inventory"] }
          }
        },
        {
          "name": "Check Stock (ADMIN/CUSTOMER)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/inventory?productId={{productId}}&quantity=1", "host": ["{{baseUrl}}"], "path": ["api","inventory"], "query": [ {"key":"productId","value":"{{productId}}"}, {"key":"quantity","value":"1"} ] }
          }
        }
      ]
    },
    {
      "name": "4. Cart (customer)",
      "item": [
        {
          "name": "Add To Cart",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200/201', () => [200,201].includes(pm.response.code));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}" },
            "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api","cart","items"] }
          }
        },
        {
          "name": "Get Cart",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.code === 200);",
            "const b = pm.response.json();",
            "if (b.items && b.items.length) { pm.collectionVariables.set('cartItemId', String(b.items[0].id)); }",
            "pm.collectionVariables.set('cartTotal', b.totalAmount);",
            "console.log('Cart total=', b.totalAmount, 'items=', b.items ? b.items.length : 0);"
          ] } } ],
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api","cart"] }
          }
        },
        {
          "name": "Update Cart Item Qty",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/cart/items/{{cartItemId}}?quantity=3", "host": ["{{baseUrl}}"], "path": ["api","cart","items","{{cartItemId}}"], "query": [ {"key":"quantity","value":"3"} ] }
          }
        }
      ]
    },
    {
      "name": "5. Order & Payment (customer)",
      "item": [
        {
          "name": "Place Order (server recomputes price)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 Created', () => pm.response.code === 201);",
            "const b = pm.response.json();",
            "pm.collectionVariables.set('orderId', String(b.id));",
            "pm.collectionVariables.set('orderNumber', b.orderNumber);",
            "pm.collectionVariables.set('orderPrice', b.price);",
            "// SECURITY DEMO: we sent price 0.01 but the server must recompute unitPrice*qty.",
            "const expected = Number(pm.collectionVariables.get('productPrice')) * 2;",
            "pm.test('server ignored forged price (recomputed = unit*qty)', () => pm.expect(Math.abs(b.price - expected)).to.be.below(0.01));",
            "console.log('Order', b.orderNumber, 'price (server) =', b.price, '(sent 0.01, expected', expected + ')');"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2,\n  \"price\": 0.01\n}" },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api","orders"] }
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api","orders","{{orderId}}"] }
          }
        },
        {
          "name": "Process Payment (Stripe test token)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// NOTE: needs a real STRIPE_API_KEY (sk_test_...) in deployment/docker/.env.",
            "// With the dummy key this returns 4xx (payment fails) but the order still exists.",
            "if (pm.response.code === 200) {",
            "  const b = pm.response.json();",
            "  pm.collectionVariables.set('paymentId', String(b.id));",
            "  pm.test('payment COMPLETED', () => pm.expect(b.status).to.eql('COMPLETED'));",
            "  console.log('Payment', b.id, 'status', b.status, 'txn', b.transactionId);",
            "} else {",
            "  console.log('Payment not completed (status', pm.response.code + ') - is STRIPE_API_KEY set? Order still persists.');",
            "}"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"orderId\": \"{{orderNumber}}\",\n  \"amount\": {{orderPrice}},\n  \"currency\": \"USD\",\n  \"stripeToken\": \"tok_visa\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api","payments"] }
          }
        },
        {
          "name": "Payment History",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/payments/history", "host": ["{{baseUrl}}"], "path": ["api","payments","history"] }
          }
        }
      ]
    },
    {
      "name": "6. Reviews & Recommendations",
      "item": [
        {
          "name": "Create Review (customer)",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('created (201) or already-reviewed (4xx)', () => [200,201,400,409].includes(pm.response.code));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great product - tested via Postman.\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/reviews", "host": ["{{baseUrl}}"], "path": ["api","reviews"] }
          }
        },
        {
          "name": "Get Product Reviews (public)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/reviews/product/{{productId}}?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api","reviews","product","{{productId}}"], "query": [ {"key":"page","value":"0"}, {"key":"size","value":"20"} ] } }
        },
        {
          "name": "Get Review Summary (public)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/reviews/product/{{productId}}/summary", "host": ["{{baseUrl}}"], "path": ["api","reviews","product","{{productId}}","summary"] } }
        },
        {
          "name": "My Reviews (customer)",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/reviews/user/me", "host": ["{{baseUrl}}"], "path": ["api","reviews","user","me"] } }
        },
        {
          "name": "Recommendations for Product (public)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/recommendations/product/{{productId}}?limit=4", "host": ["{{baseUrl}}"], "path": ["api","recommendations","product","{{productId}}"], "query": [ {"key":"limit","value":"4"} ] } }
        },
        {
          "name": "Trending (public)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/recommendations/trending?limit=5", "host": ["{{baseUrl}}"], "path": ["api","recommendations","trending"], "query": [ {"key":"limit","value":"5"} ] } }
        }
      ]
    },
    {
      "name": "7. Admin Dashboard (ADMIN)",
      "item": [
        {
          "name": "Stats",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ], "url": { "raw": "{{baseUrl}}/api/admin/stats", "host": ["{{baseUrl}}"], "path": ["api","admin","stats"] } }
        },
        {
          "name": "Recent Orders",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ], "url": { "raw": "{{baseUrl}}/api/admin/orders/recent?limit=10", "host": ["{{baseUrl}}"], "path": ["api","admin","orders","recent"], "query": [ {"key":"limit","value":"10"} ] } }
        },
        {
          "name": "Update Order Status -> SHIPPED",
          "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ], "url": { "raw": "{{baseUrl}}/api/admin/orders/{{orderId}}/status?status=SHIPPED", "host": ["{{baseUrl}}"], "path": ["api","admin","orders","{{orderId}}","status"], "query": [ {"key":"status","value":"SHIPPED"} ] } }
        },
        {
          "name": "Low Stock",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ], "url": { "raw": "{{baseUrl}}/api/admin/inventory/low-stock?threshold=100", "host": ["{{baseUrl}}"], "path": ["api","admin","inventory","low-stock"], "query": [ {"key":"threshold","value":"100"} ] } }
        },
        {
          "name": "All Users",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ], "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api","admin","users"] } }
        },
        {
          "name": "Notifications",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ], "url": { "raw": "{{baseUrl}}/api/admin/notifications", "host": ["{{baseUrl}}"], "path": ["api","admin","notifications"] } }
        }
      ]
    }
  ]
}
