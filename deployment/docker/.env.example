# ---------------------------------------------------------------------------
# Environment overrides for docker-compose. Copy this file to ".env" (same
# folder) and fill in real values. docker compose reads ".env" automatically.
#
#   copy .env.example .env        (Windows CMD)
#   cp   .env.example .env        (bash)
#
# NOTE: ".env" is gitignored — never commit real keys.
# ---------------------------------------------------------------------------

# Stripe SECRET key for the payment-service (TEST mode key starts with sk_test_).
# Get it from https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=sk_test_replace_with_your_key

# Optional: Stripe webhook signing secret (only needed if you wire up webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_xxx
